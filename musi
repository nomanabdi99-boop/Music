<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Neon Sound Matrix</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            user-select: none;
        }
        body {
            background-color: #050508;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            color: #fff;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            touch-action: manipulation;
        }
        h1 {
            font-size: 1.4rem;
            font-weight: 600;
            letter-spacing: 3px;
            color: #00f0ff;
            text-shadow: 0 0 10px rgba(0, 240, 255, 0.3);
            margin-bottom: 5px;
            text-transform: uppercase;
        }
        p {
            font-size: 0.85rem;
            color: #666680;
            margin-bottom: 20px;
        }
        /* The Grid Matrix */
        .matrix {
            display: grid;
            grid-template-columns: repeat(4, 75px);
            grid-template-rows: repeat(4, 75px);
            gap: 12px;
            background: rgba(255, 255, 255, 0.02);
            padding: 15px;
            border-radius: 24px;
            border: 1px solid rgba(255, 255, 255, 0.05);
            box-shadow: 0 20px 40px rgba(0,0,0,0.7);
        }
        /* Individual Glowing Nodes */
        .node {
            background: #101018;
            border: 1px solid #1a1a26;
            border-radius: 16px;
            cursor: pointer;
            position: relative;
            transition: background 0.4s ease, transform 0.1s ease, box-shadow 0.4s ease;
        }
        .node:active {
            transform: scale(0.92);
        }
        /* Reset Button */
        .clear-btn {
            margin-top: 25px;
            background: transparent;
            border: 1px solid #333344;
            color: #aaa;
            padding: 10px 24px;
            border-radius: 20px;
            font-size: 0.85rem;
            cursor: pointer;
            font-weight: bold;
            transition: all 0.2s;
        }
        .clear-btn:hover {
            background: #fff;
            color: #000;
            border-color: #fff;
        }
    </style>
</head>
<body>

    <h1>Neon Matrix</h1>
    <p>Tap nodes to paint with light and sound</p>

    <div class="matrix" id="grid"></div>

    <button class="clear-btn" onclick="clearMatrix()">Reset Canvas</button>

    <script>
        const grid = document.getElementById('grid');
        const totalNodes = 16;
        
        // A beautiful pentatonic musical scale so everything sounds amazing together
        // Frequencies correspond to standard musical notes (C, D, E, G, A, etc.)
        const scale = [
            523.25, 493.88, 440.00, 392.00, 
            349.23, 329.63, 293.66, 261.63,
            220.00, 196.00, 174.61, 164.81,
            146.83, 130.81, 110.00, 98.00
        ];

        // Unique vivid neon colors matching the musical frequencies
        const colors = [
            '#ff0055', '#ff5500', '#ffaa00', '#ffee00',
            '#aaff00', '#55ff00', '#00ff55', '#00ffaa',
            '#00ffff', '#00aaff', '#0055ff', '#5500ff',
            '#aa00ff', '#ff00aa', '#ff0055', '#ff3366'
        ];

        // Initialize Audio context safely
        const AudioContext = window.AudioContext || window.webkitAudioContext;
        const audioCtx = new AudioContext();

        // Build the 16 nodes programmatically
        for (let i = 0; i < totalNodes; i++) {
            const node = document.createElement('div');
            node.classList.add('node');
            
            // Touch/Click event
            node.addEventListener('pointerdown', (e) => {
                e.preventDefault();
                triggerNode(node, i);
            });
            
            grid.appendChild(node);
        }

        function triggerNode(element, index) {
            if (audioCtx.state === 'suspended') {
                audioCtx.resume();
            }

            // Visual feedback: Glow up with the specific color
            const targetColor = colors[index];
            element.style.background = targetColor;
            element.style.boxShadow = `0 0 25px ${targetColor}, inset 0 0 10px rgba(255,255,255,0.6)`;
            element.style.borderColor = '#ffffff';

            // Play the synthesizer note
            playNote(scale[index]);

            // Gradually fade the glow back to dark space
            setTimeout(() => {
                element.style.background = '#101018';
                element.style.boxShadow = 'none';
                element.style.borderColor = '#1a1a26';
            }, 600);
        }

        function playNote(frequency) {
            const osc = audioCtx.createOscillator();
            const gainNode = audioCtx.createGain();
            
            osc.type = 'sine'; // Clean, pure bell-like tone
            osc.frequency.setValueAtTime(frequency, audioCtx.currentTime);
            
            // Smooth sound envelope so it doesn't "pop" your ears
            gainNode.gain.setValueAtTime(0.4, audioCtx.currentTime);
            gainNode.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.8);
            
            osc.connect(gainNode);
            gainNode.connect(audioCtx.destination);
            
            osc.start();
            osc.stop(audioCtx.currentTime + 0.8);
        }

        function clearMatrix() {
            const nodes = document.querySelectorAll('.node');
            nodes.forEach(node => {
                node.style.background = '#101018';
                node.style.boxShadow = 'none';
                node.style.borderColor = '#1a1a26';
            });
        }
    </script>
</body>
</html>
